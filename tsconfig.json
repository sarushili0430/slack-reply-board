{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals", "vite/client"],
    "noEmit": true
  },
  "include": [
    "*.ts",
    "*.mts",
    "*.cts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": ["node_modules", "dist", "out", "coverage", ".vite"]
}
